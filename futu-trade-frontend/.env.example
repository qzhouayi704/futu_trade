# Next.js 前端环境变量配置示例
# 复制此文件为 .env.local 并根据需要修改

# ============================================
# 后端 API 地址配置
# ============================================

# FastAPI 版本（推荐，端口 5001）
NEXT_PUBLIC_API_URL=http://localhost:5001
FLASK_API_URL=http://localhost:5001

# Flask 版本（兼容，端口 5000）
# NEXT_PUBLIC_API_URL=http://localhost:5000
# FLASK_API_URL=http://localhost:5000

# ============================================
# 说明
# ============================================
#
# NEXT_PUBLIC_API_URL:
#   - 客户端可访问的 API 地址
#   - 用于浏览器端的 API 调用
#
# FLASK_API_URL:
#   - 服务端 API 代理地址
#   - 用于 Next.js API 路由的后端代理
#
# 注意：
#   - 修改环境变量后需要重启前端服务
#   - FastAPI 版本使用端口 5001
#   - Flask 版本使用端口 5000
