# 富途量化交易系统 - 环境变量配置示例
#
# 使用方法：
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. 环境变量会覆盖 config.json 中的对应配置
#
# 注意：环境变量仅覆盖部署相关的关键配置，不会覆盖所有配置项

# ==================== 连接配置 ====================
# 富途OpenD主机地址
# FUTU_HOST=127.0.0.1

# 富途OpenD端口
# FUTU_PORT=11111

# 数据库路径
# FUTU_DATABASE_PATH=simple_trade/data/trade.db

# ==================== 交易配置 ====================
# 自动交易开关 (true/false, 1/0, yes/no)
# FUTU_AUTO_TRADE=true

# 数据更新间隔（秒）
# FUTU_UPDATE_INTERVAL=60

# ==================== 监控配置 ====================
# 最大订阅股票数量
# FUTU_MAX_SUBSCRIPTION_STOCKS=300

# ==================== Gemini AI 配置 ====================
# Gemini API 密钥（必需，用于新闻智能分析）
# GEMINI_API_KEY=your_api_key_here
# Gemini 模型名称
# GEMINI_MODEL=gemini-3-flash-preview
# 是否启用（有 API key 时默认启用）
# GEMINI_ENABLED=true
# 超时时间（秒）
# GEMINI_TIMEOUT=30
